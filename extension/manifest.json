{
  "manifest_version": 3,
  "name": "Wheel Strategy Screener Helper",
  "version": "0.1.9",
  "description": "Local helper that reads Robinhood screener list symbols in the user's browser session.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Wheel Strategy Screener Helper",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "https://robinhood.com/*",
    "https://*.robinhood.com/*",
    "https://wheelstrategyscreener.com/*",
    "https://www.wheelstrategyscreener.com/*",
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*",
    "http://localhost:5174/*",
    "http://127.0.0.1:5174/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://wheelstrategyscreener.com/*",
        "https://www.wheelstrategyscreener.com/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "http://localhost:5174/*",
        "http://127.0.0.1:5174/*"
      ],
      "js": ["content-app.js"]
    },
    {
      "matches": ["https://robinhood.com/*", "https://*.robinhood.com/*"],
      "js": ["content-robinhood.js"]
    }
  ]
}
